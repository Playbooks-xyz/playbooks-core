{
	"name": "@playbooks/normalizers",
	"version": "0.15.0",
	"description": "A collection of normalizers for Playbooks.",
	"author": "Eric Hubbell<eric@erichubbell.com>",
	"license": "ISC",
	"type": "module",
	"main": "dist/index.cjs",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/playbooks-xyz/playbooks-core.git"
	},
	"files": [
		"dist"
	],
	"keywords": [
		"playbooks",
		"normalizers",
		"data"
	],
	"scripts": {
		"dev": "vite build --mode development --minify false --watch",
		"start": "vite build --mode production --minify false --watch",
		"build": "vite build --mode production --minify true",
		"build:ts": "tsc --project tsconfig.json --noEmit false && tsc-alias",
		"build:dts": "dts-bundle-generator --config dts.config.ts",
		"lint": "eslint src",
		"lint:fix": "eslint src --fix",
		"format": "prettier --check src",
		"format:fix": "prettier --write src",
		"reset": "rm -rf package-lock.json node_modules",
		"clean": "npm run lint:fix",
		"commit": "scripts/commit.sh",
		"deploy": "scripts/deploy.sh",
		"packages": "scripts/packages.sh",
		"git": "git push --tags",
		"test": "jest",
		"prepare": "husky"
	},
	"devDependencies": {
		"@playbooks/utils": "^0.13.4"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		},
		"./base-normalizer": {
			"types": "./dist/base-normalizer.d.ts",
			"import": "./dist/base-normalizer.js",
			"require": "./dist/base-normalizer.cjs"
		},
		"./json-api-normalizer": {
			"types": "./dist/json-api-normalizer.d.ts",
			"import": "./dist/json-api-normalizer.js",
			"require": "./dist/json-api-normalizer.cjs"
		}
	}
}
