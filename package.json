{
  "name": "@playbooks/core",
  "version": "0.0.0",
  "description": "A collection of resources for Playbooks.",
  "author": "Eric Hubbell<eric@erichubbell.com>",
  "license": "ISC",
  "scripts": {
    "start": "npm start --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "build:ts": "npm run build:ts --workspaces --if-present",
    "build:dts": "npm run build:dts --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "lint:fix": "npm run lint:fix --workspaces --if-present",
    "format": "npm run format --workspaces --if-present",
    "format:fix": "npm run format:fix --workspaces --if-present",
    "reset": "npm run reset --workspaces --if-present",
    "postreset": "rm -rf package-lock.json node_modules",
    "commit": "scripts/commit.sh",
    "deploy": "npm run deploy --workspaces --if-present",
    "packages": "npm run packages --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "prepare": "husky"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/jest": "^29.5.1",
    "@types/react": "^18.0.26",
    "@types/react-dom": "^18.0.9",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitejs/plugin-react": "^4.5.2",
    "dts-bundle-generator": "^9.5.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-complete": "1.4.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^13.24.0",
    "husky": "^9.1.7",
    "jest": "^29.5.0",
    "prettier": "^3.8.1",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.1",
    "tsc-alias": "^1.8.16",
    "tsc-extensions": "^0.0.7",
    "tslib": "^2.8.1",
    "typescript": "^5.8.3",
    "vite": "^7.0.0",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-size": "^0.1.4",
    "vite-plugin-yalc": "^0.0.18"
  },
  "workspaces": [
    "packages/adapters",
    "packages/normalizers",
    "packages/serializers",
    "packages/utils"
  ]
}
